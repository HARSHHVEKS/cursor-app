*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Editors / OS ---
.vscode/
.idea/
*.swp
.DS_Store

# --- Runtime / logs ---
*.log

